@model SV22T1020247.Models.Catalog.Product
@{
    // Biến lưu đường dẫn ảnh từ project Admin
    string adminImageBaseUrl = "https://localhost:7219/images/products/";

    ViewData["Title"] = "Chi tiết sản phẩm";
    // Nhận dữ liệu từ Controller
    var photos = ViewBag.Photos as IEnumerable<SV22T1020247.Models.Catalog.ProductPhoto>;
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020247.Models.Catalog.ProductAttribute>;
}

<div class="container mt-4 mb-5">
    <a href="~/" class="text-decoration-none text-muted mb-4 d-inline-block">
        <i class="bi bi-arrow-left"></i> Tiếp tục mua sắm
    </a>

    <div class="row bg-white p-4 shadow-sm rounded">
        <div class="col-md-5 mb-4 mb-md-0 text-center">

            <img id="mainImage"
                 src="@adminImageBaseUrl@(string.IsNullOrEmpty(Model.Photo) ? "no-image.jpg" : Model.Photo)"
                 class="img-fluid rounded border p-2 mb-3"
                 alt="@Model.ProductName"
                 style="height: 350px; width: 100%; object-fit: contain;"
                 onerror="this.onerror=null; this.src='/images/no-image.jpg';">

            @if (photos != null && photos.Any())
            {
                <div class="d-flex justify-content-center gap-2 overflow-auto py-2">

                    <img src="@adminImageBaseUrl@(string.IsNullOrEmpty(Model.Photo) ? "no-image.jpg" : Model.Photo)"
                         class="border rounded cursor-pointer thumbnail-img active"
                         style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;"
                         onclick="changeImage(this.src)"
                         onerror="this.onerror=null; this.src='/images/no-image.jpg';">

                    @foreach (var img in photos)
                    {
                        <img src="@adminImageBaseUrl@img.Photo"
                             class="border rounded cursor-pointer thumbnail-img"
                             style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;"
                             onclick="changeImage(this.src)"
                             onerror="this.onerror=null; this.src='/images/no-image.jpg';">
                    }
                </div>
            }
        </div>

        <div class="col-md-7 pl-md-5 d-flex flex-column">
            <h2 class="fw-bold mb-3">@Model.ProductName</h2>

            <div class="bg-light p-3 rounded mb-4">
                <h3 class="text-danger fw-bold m-0">@Model.Price.ToString("N0") đ</h3>
            </div>

            <div class="mb-4">
                <p class="mb-2"><strong>Đơn vị tính:</strong> @Model.Unit</p>
                <p class="mb-2 text-success"><i class="bi bi-check-circle-fill"></i> Tình trạng: Còn hàng</p>
            </div>

            @if (attributes != null && attributes.Any())
            {
                <h5 class="fw-bold mt-2 mb-3">Thông số kỹ thuật</h5>
                <table class="table table-bordered table-sm mb-4">
                    <tbody>
                        @foreach (var attr in attributes)
                        {
                            <tr>
                                <th class="bg-light" style="width: 30%;">@attr.AttributeName</th>
                                <td>@attr.AttributeValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <hr class="mt-auto mb-4" />

            <form action="~/Cart/AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.ProductID" />

                <div class="row align-items-center mb-4">
                    <div class="col-auto">
                        <label for="quantity" class="col-form-label fw-bold">Số lượng:</label>
                    </div>
                    <div class="col-auto">
                        <input type="number" id="quantity" name="quantity" class="form-control text-center fw-bold" value="1" min="1" style="width: 100px;">
                    </div>
                </div>

                <div class="d-grid gap-2 d-md-block">
                    <button type="submit" class="btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm">
                        <i class="bi bi-cart-plus me-2 fs-5"></i> THÊM VÀO GIỎ HÀNG
                    </button>
                </div>
            </form>

        </div>
    </div>

    <div class="row bg-white p-4 shadow-sm rounded mt-4">
        <div class="col-12">
            <h4 class="fw-bold mb-4 border-bottom pb-2">Mô tả sản phẩm</h4>

            <div class="product-description" style="line-height: 1.8;">
                @if (string.IsNullOrWhiteSpace(Model.ProductDescription))
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-info-circle fs-1 mb-2 d-block"></i>
                        <p class="mb-0 fst-italic">Sản phẩm này hiện tại chưa có mô tả chi tiết.</p>
                    </div>
                }
                else
                {
                    @Html.Raw(Model.ProductDescription)
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Script nhỏ giúp đổi ảnh chính khi click vào ảnh thu nhỏ
        function changeImage(src) {
            document.getElementById('mainImage').src = src;
        }
    </script>
}