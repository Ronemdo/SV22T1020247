@model IEnumerable<SV22T1020247.Shop.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
    decimal totalCart = Model.Sum(i => i.TotalPrice);
}

<div class="container mt-5 mb-5">
    <div class="row g-4">
        <div class="col-md-7">
            <div class="card shadow-sm border-0 p-4 rounded-3">
                <h4 class="fw-bold mb-4 text-dark"><i class="bi bi-truck me-2"></i>Thông tin giao hàng</h4>

                <form action="~/Cart/InitOrder" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Tỉnh/Thành phố *</label>
                        <select name="deliveryProvince" class="form-select form-select-lg fs-6" required>
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            @foreach (var p in ViewBag.Provinces)
                            {
                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small text-uppercase">Số điện thoại nhận hàng *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-telephone"></i></span>
                            <input type="tel" name="Phone" class="form-control form-control-lg fs-6"
                                   
                                   pattern="[0-9]{10,11}"
                                   title="Vui lòng nhập số điện thoại hợp lệ (10-11 chữ số)"
                                   required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Địa chỉ chi tiết *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                            <input type="text" name="deliveryAddress" class="form-control form-control-lg fs-6"
                                   placeholder="Số nhà, tên đường, phường/xã..." required>
                        </div>
                    </div>

                    <div class="pt-2">
                        <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold rounded-pill shadow-sm py-3 text-uppercase"
                                style="background: linear-gradient(135deg, #A52A2A 0%, #8B0000 100%); border: none;">
                            <i class="bi bi-check2-circle me-2"></i>XÁC NHẬN ĐẶT HÀNG
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 p-4 bg-light rounded-3" style="border-left: 4px solid #A52A2A !important;">
                <h5 class="fw-bold mb-4 text-dark">Đơn hàng của bạn (@Model.Count() món)</h5>

                <div class="cart-items-summary mb-3" style="max-height: 300px; overflow-y: auto;">
                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div style="max-width: 70%;">
                                <div class="fw-bold text-truncate" title="@item.ProductName">@item.ProductName</div>
                                <small class="text-muted">Số lượng: @item.Quantity</small>
                            </div>
                            <span class="fw-bold text-dark">@item.TotalPrice.ToString("N0") đ</span>
                        </div>
                    }
                </div>

                <hr class="my-4">

                <div class="d-flex justify-content-between align-items-center">
                    <span class="fs-5 fw-bold">Tổng thanh toán:</span>
                    <div class="text-end">
                        <span class="fs-4 fw-bold text-danger">@totalCart.ToString("N0") đ</span>
                        <div class="small text-muted">(Đã bao gồm VAT)</div>
                    </div>
                </div>
            </div>

            <div class="mt-3 p-2 text-center text-muted small">
                <i class="bi bi-shield-check me-1"></i> Thanh toán an toàn & bảo mật
            </div>
        </div>
    </div>
</div>