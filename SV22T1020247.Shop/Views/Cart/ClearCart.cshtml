@{
    ViewBag.Title = "Xác nhận xóa giỏ hàng";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Xác nhận xóa toàn bộ giỏ hàng</h4>
                </div>
                <div class="card-body text-center p-4">
                    <h5 class="text-danger mb-4">Bạn có chắc chắn muốn xóa toàn bộ sản phẩm khỏi giỏ hàng không?</h5>
                    <p class="text-muted">Hành động này không thể hoàn tác. Bạn sẽ phải thêm lại từng sản phẩm nếu muốn đặt hàng.</p>

                    <form action="~/Cart/ClearCart" method="post" class="mt-4">
                        <a href="~/Cart/Index" class="btn btn-secondary px-4 me-2">
                            <i class="bi bi-arrow-left"></i> Quay lại
                        </a>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash"></i> Đồng ý xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>