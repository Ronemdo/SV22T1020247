@using SV22T1020247.BusinessLayers
@using SV22T1020247.Models.Common
@using Microsoft.AspNetCore.Http
@using System.Text.Json
@using SV22T1020247.Shop.Models
@inject IHttpContextAccessor HttpContextAccessor

@{
    var catInput = new PaginationSearchInput() { Page = 1, PageSize = 50, SearchValue = "" };
    var catResult = await PartnerDataService.ListCategoriesAsync(catInput);
    var categoryList = catResult.DataItems;
    int cartCount = 0;

    var sessionData = HttpContextAccessor.HttpContext?.Session.GetString("ShoppingCart");
    if (!string.IsNullOrEmpty(sessionData))
    {
        var cart = JsonSerializer.Deserialize<List<CartItem>>(sessionData);
        if (cart != null)
        {
            cartCount = cart.Sum(i => i.Quantity);
        }
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NhatNam Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* CSS Tùy Chỉnh Cho Giao Diện Chuyên Nghiệp */
        body {
            background-color: #f4f6f9; /* Màu nền xám nhẹ dịu mắt */
        }

        /* Header */
        .sticky-top {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(5px); /* Hiệu ứng mờ nền khi cuộn */
        }

        .navbar-brand img {
            transition: transform 0.3s ease;
        }

        .navbar-brand:hover img {
            transform: scale(1.05); /* Hiệu ứng phóng to nhẹ khi hover logo */
        }

        /* Ô tìm kiếm */
        .search-form .input-group {
            border: 2px solid transparent;
            transition: border-color 0.3s;
        }

            .search-form .input-group:focus-within {
                border-color: #dc3545; /* Đổi màu viền khi click vào */
                box-shadow: 0 0 10px rgba(220, 53, 69, 0.1);
            }

        /* Nút giỏ hàng */
        .nav-cart-btn {
            transition: all 0.3s ease;
        }

            .nav-cart-btn:hover {
                background-color: #dc3545 !important;
                color: white !important;
                transform: translateY(-2px);
            }

        /* Dropdown User */
        .dropdown-menu {
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .dropdown-hover:hover {
            background-color: #f8f9fa;
        }

        /* Hero Banner (Phần được thêm) */
        .hero-banner {
            background-color: #212529; /* Màu nền tối nếu chưa có ảnh */
            color: white;
            padding: 60px 0;
            background-size: cover;
            background-position: center;
        }

        /* Footer */
        .footer-link {
            text-decoration: none;
            color: #adb5bd;
            transition: color 0.2s;
        }

            .footer-link:hover {
                color: white;
                padding-left: 5px; /* Hiệu ứng dịch chuyển nhẹ khi hover */
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <header class="sticky-top shadow-sm bg-white">
        <nav class="navbar navbar-expand-lg navbar-light py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3 d-flex align-items-center text-dark" href="~/">
                    <i class="bi bi-shop text-danger me-2 fs-2"></i>
                    NhatNam<span class="text-danger">-Shop</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <form class="d-flex mx-auto search-form mt-3 mt-lg-0" style="width: 100%; max-width: 500px;" action="~/Home/Index" method="get">
                        <div class="input-group rounded-pill overflow-hidden border">
                            <input class="form-control border-0 shadow-none px-4 bg-light" type="search" name="searchValue" placeholder="Bạn cần tìm thiết bị gì hôm nay?">
                            <button class="btn btn-danger btn-search text-white fw-bold px-4" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center mt-3 mt-lg-0">
                        <li class="nav-item me-3">
                            <a href="~/Cart" class="btn btn-light position-relative rounded-circle shadow-sm d-flex justify-content-center align-items-center p-0 nav-cart-btn" style="width: 48px; height: 48px;">
                                <i class="bi bi-cart3 fs-5"></i>
                                @if (cartCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-light">
                                        @cartCount
                                    </span>
                                }
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown ms-2">
                                <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center bg-light rounded-pill px-3 py-2 shadow-sm"
                                   href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle fs-5 text-success me-2"></i> @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 rounded-3" aria-labelledby="userDropdown">
                                    <li><h6 class="dropdown-header text-dark">Tài khoản của tôi</h6></li>
                                    <li><a class="dropdown-item py-2 dropdown-hover" href="~/Order/Index"><i class="bi bi-box-seam me-2 text-primary"></i> Đơn hàng của tôi</a></li>
                                    <li><a class="dropdown-item py-2 dropdown-hover" href="~/Account/Profile"><i class="bi bi-person-vcard me-2 text-info"></i> Quản lý hồ sơ</a></li>
                                    <li><a class="dropdown-item py-2 dropdown-hover" href="~/Account/ChangePassword"><i class="bi bi-lock me-2 text-warning"></i> Đổi mật khẩu</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-danger fw-bold dropdown-hover" href="~/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-2">
                                <a class="btn btn-outline-danger px-4 rounded-pill fw-bold" href="~/Account/Login">
                                    <i class="bi bi-person-fill me-1"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @*<div class="hero-banner shadow" style="background-image: url('/images/main-banner.jpg');"> *@
    <div class="hero-banner shadow" style="background-image: url('/images/main-banner.jpg');">
        <div class="container">
            <h1 class="fw-bold display-4">Thế Giới Mua Sắm</h1>
            <p class="lead">Chất lượng hàng đầu, uy tín trọn đời. Khám phá ngay!</p>
            <a href="~/" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold mt-3 shadow">Mua sắm ngay</a>
        </div>
    </div>

    <main class="container my-5 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light pt-5 pb-3 mt-auto border-top border-4 border-danger shadow-lg">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <a class="fw-bold text-white fs-3 text-decoration-none mb-3 d-inline-block" href="~/">
                        <i class="bi bi-shop text-danger me-2"></i>NhatNam<span class="text-danger">-Shop</span>
                    </a>
                    <p class="text-secondary pe-md-4 mt-2">Hệ thống bán lẻ các thiết bị điện tử, đồ gia dụng và thời trang hàng đầu Việt Nam. Chất lượng làm nên uy tín.</p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="text-secondary fs-4 footer-icon-hover"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-secondary fs-4 footer-icon-hover"><i class="bi bi-youtube text-danger"></i></a>
                        <a href="#" class="text-secondary fs-4 footer-icon-hover"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="text-secondary fs-4 footer-icon-hover"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold text-white mb-4">Thông tin liên hệ</h5>
                    <ul class="list-unstyled text-secondary">
                        <li class="mb-3 d-flex"><i class="bi bi-geo-alt mt-1 me-2 text-danger"></i> <span>77 Nguyễn Huệ, TP. Huế</span></li>
                        <li class="mb-3"><i class="bi bi-telephone me-2 text-danger"></i> Hotline: <strong class="text-white">1900 1080</strong></li>
                        <li class="mb-3"><i class="bi bi-envelope me-2 text-danger"></i> cskh@nhatnamshop.vn</li>
                        <li class="mb-3"><i class="bi bi-clock me-2 text-danger"></i> 8h - 22h (Cả T7 & CN)</li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="fw-bold text-white mb-4">Hỗ trợ</h5>
                    <ul class="list-unstyled">
                        <li class="mb-3"><a href="#" class="footer-link">Chính sách bảo mật</a></li>
                        <li class="mb-3"><a href="#" class="footer-link">Chính sách đổi trả</a></li>
                        <li class="mb-3"><a href="#" class="footer-link">Chính sách bảo hành</a></li>
                        <li class="mb-3"><a href="#" class="footer-link">Điều khoản dịch vụ</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="fw-bold text-white mb-4">Nhận bản tin</h5>
                    <p class="text-secondary small">Nhận thông tin mã giảm giá mới nhất.</p>
                    <form class="d-flex mt-3 shadow-sm rounded overflow-hidden">
                        <input type="email" class="form-control bg-light border-0 px-3 py-2" placeholder="Email của bạn...">
                        <button class="btn btn-danger px-3 py-2" type="button"><i class="bi bi-send-fill"></i></button>
                    </form>
                </div>
            </div>
            <div class="border-top border-secondary pt-4 mt-4 text-center text-secondary small">
                &copy; 2026 Bản quyền thuộc về NhatNam Shop. Nền tảng SV22T1020247.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>