@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập & Đăng ký - NhatNam Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background: #f0f2f5;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .auth-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-card {
            display: flex;
            width: 100%;
            max-width: 950px;
            height: 550px; /* Chiều cao cố định để không bị cuộn */
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        /* Phía bên trái: Banner */
        .auth-banner {
            flex: 1;
            background: linear-gradient(135deg, #A52A2A 0%, #631212 100%);
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .benefit-box {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

        .benefit-icon {
            font-size: 1.5rem;
            margin-right: 15px;
        }

        /* Phía bên phải: Form */
        .auth-form {
            flex: 1.2;
            padding: 40px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-floating {
            margin-bottom: 15px !important;
        }

        .btn-crimson {
            background: #A52A2A;
            border: none;
            color: white;
            padding: 12px;
            font-weight: bold;
            border-radius: 50px;
            transition: 0.3s;
        }

            .btn-crimson:hover {
                background: #8B0000;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(165, 42, 42, 0.3);
            }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #A52A2A;
            text-decoration: none;
            font-weight: 600;
            z-index: 10;
        }
    </style>
</head>
<body>

    <a href="/" class="back-home">← Quay lại cửa hàng</a>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-banner d-none d-md-flex">
                <h2 class="fw-bold mb-2">NhatNam-Shop</h2>
                <div class="mb-4" style="width: 40px; height: 3px; background: white;"></div>
                <h1 class="display-6 fw-bold mb-4">Tham gia ngay hôm nay.</h1>

                <div class="benefit-box">
                    <span class="benefit-icon">🛡️</span>
                    <div>
                        <div class="fw-bold">Bảo mật</div>
                        <small class="opacity-75">An toàn thông tin 100%</small>
                    </div>
                </div>

                <div class="benefit-box">
                    <span class="benefit-icon">🎁</span>
                    <div>
                        <div class="fw-bold">Ưu đãi</div>
                        <small class="opacity-75">Voucher cho thành viên mới</small>
                    </div>
                </div>

                <div class="mt-4 opacity-50 small">© 2024 NhatNam-Shop</div>
            </div>

            <div class="auth-form">
                <h3 class="fw-bold mb-4" style="color: #4B1010;">Đăng ký tài khoản</h3>

                <form action="~/Account/Register" method="post">
                    <div class="form-floating">
                        <input type="text" class="form-control" name="customerName" required placeholder="Họ tên">
                        <label>Họ và tên *</label>
                    </div>

                    <div class="form-floating">
                        <input type="email" class="form-control" name="email" required placeholder="Email">
                        <label>Email *</label>
                    </div>

                    <div class="form-floating">
                        <input type="password" class="form-control" name="password" required placeholder="Mật khẩu">
                        <label>Mật khẩu *</label>
                    </div>

                    <div class="form-floating">
                        <select class="form-select" name="province" required>
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            @if (ViewBag.Provinces != null)
                            {
                                foreach (var item in ViewBag.Provinces)
                                {
                                    <option value="@item.ProvinceName">@item.ProvinceName</option>
                                }
                            }
                        </select>
                        <label>Tỉnh/Thành *</label>
                    </div>

                    <button type="submit" class="btn btn-crimson w-100 text-uppercase mt-2">Đăng ký ngay</button>

                    <div class="text-center mt-4 small">
                        <span class="text-muted">Đã có tài khoản?</span>
                        <a href="~/Account/Login" class="text-danger fw-bold text-decoration-none">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>