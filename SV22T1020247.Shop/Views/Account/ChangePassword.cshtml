@{
    ViewBag.Title = "Đổi mật khẩu";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .auth-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .auth-header {
        background: linear-gradient(135deg, #A52A2A 0%, #631212 100%);
        padding: 35px 20px;
        text-align: center;
        color: white;
    }

    .lock-icon-circle {
        width: 70px;
        height: 70px;
        background: rgba(255,255,255,0.2);
        border: 3px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 2rem;
    }

    .form-label {
        color: #4B1010;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: bold;
        margin-bottom: 8px;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #dee2e6;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #A52A2A;
            box-shadow: 0 0 0 0.25rem rgba(165, 42, 42, 0.1);
        }

    .input-group-text {
        background: none;
        border-right: none;
        color: #A52A2A;
    }

    .has-icon .form-control {
        border-left: none;
    }

    .btn-crimson {
        background: linear-gradient(135deg, #A52A2A 0%, #8B0000 100%);
        border: none;
        color: white;
        padding: 14px;
        font-weight: bold;
        border-radius: 50px;
        transition: 0.3s;
        letter-spacing: 0.5px;
    }

        .btn-crimson:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(165,42,42,0.3);
            color: white;
        }

    .btn-outline-custom {
        border: 2px solid #e9ecef;
        color: #6c757d;
        padding: 12px;
        font-weight: 600;
        border-radius: 50px;
        transition: 0.3s;
        text-decoration: none;
        display: block; /* Sửa lại để hiển thị đúng dạng block trong d-grid */
    }

        .btn-outline-custom:hover {
            border-color: #ced4da;
            background-color: #f8f9fa;
            color: #495057;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card auth-card">

                <div class="auth-header">
                    <div class="lock-icon-circle">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <h4 class="fw-bold mb-1">Đổi mật khẩu</h4>
                    <p class="mb-0 small opacity-75">Tăng cường bảo mật cho tài khoản của bạn</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form action="~/Account/ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label">Mật khẩu hiện tại</label>
                            <div class="input-group has-icon">
                                <span class="input-group-text"><i class="bi bi-unlock"></i></span>
                                <input type="password" class="form-control" name="oldPassword" placeholder="Nhập mật khẩu đang dùng" required />
                            </div>
                        </div>

                        <hr class="my-4 opacity-25" />

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <div class="input-group has-icon">
                                <span class="input-group-text"><i class="bi bi-key"></i></span>
                                <input type="password" class="form-control" name="newPassword" placeholder="Tạo mật khẩu mới" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Xác nhận mật khẩu mới</label>
                            <div class="input-group has-icon">
                                <span class="input-group-text"><i class="bi bi-check-circle"></i></span>
                                <input type="password" class="form-control" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required />
                            </div>
                        </div>

                        <div class="d-grid gap-3 mt-5">
                            <button type="submit" class="btn btn-crimson text-uppercase">
                                <i class="bi bi-save me-2"></i> Cập nhật mật khẩu
                            </button>
                            <a href="~/Account/Profile" class="btn btn-outline-custom text-center">
                                <i class="bi bi-arrow-left me-2"></i> Quay lại hồ sơ
                            </a>
                        </div>

                        @Html.ValidationSummary(true, "", new { @class = "text-danger mt-4 small text-center fw-bold" })
                    </form>
                </div>
            </div>

            <div class="text-center mt-4 mb-5 text-muted small">
                <i class="bi bi-info-circle me-1"></i> Mật khẩu nên dài ít nhất 8 ký tự và chứa cả số lẫn chữ.
            </div>

        </div>
    </div>
</div>