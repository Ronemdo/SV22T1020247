@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - NhatNam Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        /* 1. Cấu hình nền và chặn cuộn trang */
        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            background: #f0f2f5; /* Màu nền xám nhạt trung tính */
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        /* 2. Container căn giữa tuyệt đối */
        .auth-container {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .auth-card {
            display: flex;
            width: 100%;
            max-width: 900px;
            height: 500px; /* Chiều cao cố định cho trang Login */
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            overflow: hidden;
        }

        /* 3. Bên trái: Banner màu Crimson */
        .auth-banner {
            flex: 1;
            background: linear-gradient(135deg, #A52A2A 0%, #631212 100%);
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-icon {
            font-size: 3rem;
            margin-bottom: 20px;
            background: rgba(255,255,255,0.1);
            width: 70px;
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 15px;
        }

        /* 4. Bên phải: Form đăng nhập */
        .auth-form-side {
            flex: 1.2;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* Đồng bộ style Input với trang Register */
        .form-floating {
            margin-bottom: 15px !important;
        }

        .form-control:focus {
            border-color: #A52A2A;
            box-shadow: 0 0 0 0.25rem rgba(165, 42, 42, 0.1);
        }

        .btn-crimson {
            background: linear-gradient(135deg, #A52A2A 0%, #8B0000 100%);
            border: none;
            color: white;
            padding: 14px;
            font-weight: bold;
            border-radius: 50px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

            .btn-crimson:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(165, 42, 42, 0.3);
                color: white;
            }

        .back-home {
            position: absolute;
            top: 25px;
            left: 25px;
            color: #A52A2A;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.2s;
        }

            .back-home:hover {
                opacity: 0.7;
            }
    </style>
</head>
<body>

    <a href="/" class="back-home">← QUAY LẠI CỬA HÀNG</a>

    <div class="auth-container">
        <div class="auth-card">

            <div class="auth-banner d-none d-md-flex">
                <div class="login-icon">🔓</div>
                <h2 class="fw-bold mb-3">Chào mừng quay trở lại!</h2>
                <p class="opacity-75">Đăng nhập để tiếp tục trải nghiệm mua sắm tuyệt vời tại NhatNam-Shop.</p>
                <div class="mt-4" style="width: 50px; height: 3px; background: white;"></div>
                <div class="mt-auto opacity-50 small">© 2024 NhatNam-Shop</div>
            </div>

            <div class="auth-form-side">
                <div class="mb-4">
                    <h3 class="fw-bold" style="color: #4B1010;">Đăng nhập</h3>
                    <p class="text-muted small">Vui lòng nhập Email và Mật khẩu của bạn</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        @Html.ValidationSummary(true, "")
                    </div>
                }
                @if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-3">
        @TempData["SuccessMessage"]
    </div>
}
                <form action="~/Account/Login" method="post">
                    <div class="form-floating">
                        <input type="email" name="email" class="form-control" id="emailInput" placeholder="name@example.com" required>
                        <label for="emailInput">Email của bạn</label>
                    </div>

                    <div class="form-floating">
                        <input type="password" name="password" class="form-control" id="passInput" placeholder="Password" required>
                        <label for="passInput">Mật khẩu</label>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label small text-muted" for="rememberMe" style="cursor:pointer">
                                Ghi nhớ tôi
                            </label>
                        </div>
                        
                    </div>

                    <button type="submit" class="btn btn-crimson w-100 shadow-sm">Đăng nhập ngay</button>

                    <div class="text-center mt-4">
                        <p class="small text-muted mb-0">
                            Bạn mới đến đây?
                            <a href="~/Account/Register" class="text-danger text-decoration-none fw-bold">Tạo tài khoản mới</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>

</body>
</html>