@model SV22T1020247.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Bổ sung thuộc tính";
}

@section PageToolBar {
    <button type="submit" form="formCreate" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="~/Product/Edit/@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Bổ sung thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form id="formCreate" action="~/Product/SaveAttribute" method="post">
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Tên thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   class="form-control"
                                   value="@Model.AttributeName"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Giá trị thuộc tính</label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   class="form-control"
                                   value="@Model.AttributeValue"
                                   placeholder="Ví dụ: Đỏ, XL, 500g" />
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@Model.DisplayOrder"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>