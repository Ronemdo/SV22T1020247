

@{
    ViewBag.Title = "Add New Shipper"; // Trình độ B1: Sử dụng tiếng Anh chuyên ngành
}

<div class="box box-primary">
    <div class="box-header with-border">
        <h3 class="box-title">@ViewBag.Title</h3>
    </div>

    <form action="~/Shipper/Save" method="post">
        @* Truyền ID = 0 để hệ thống biết là Create *@
        <input type="hidden" name="ShipperID" value="0" />

        <div class="box-body">
            <div class="form-group">
                <label>Shipper Name (Tên người giao hàng):</label>
                <input type="text" class="form-control" name="ShipperName" autofocus required>
                @Html.ValidationMessage("ShipperName", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label>Phone Number (Điện thoại):</label>
                <input type="text" class="form-control" name="Phone">
            </div>
        </div>

        <div class="box-footer text-right">
            <button type="submit" class="btn btn-primary">
                <i class="fa fa-save"></i> Save Shipper
            </button>
            <a href="~/Shipper" class="btn btn-default">
                Cancel
            </a>
        </div>
    </form>
</div>
