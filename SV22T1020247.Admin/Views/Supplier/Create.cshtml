@* Thiết lập tiêu đề cho Layout *@
@{
    ViewBag.Title = "Bổ sung Nhà cung cấp";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">Thông tin nhà cung cấp</h5>
    </div>
    <div class="card-body">
        <form action="/Supplier/Create" method="post">
            <div class="row">
                @* Cột bên trái *@
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên nhà cung cấp:</label>
                        <input type="text" name="SupplierName" class="form-control" placeholder="Nhập tên nhà cung cấp" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên giao dịch:</label>
                        <input type="text" name="ContactName" class="form-control" placeholder="Nhập tên giao dịch">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Điện thoại:</label>
                        <input type="tel" name="Phone" class="form-control" placeholder="Ví dụ: 024.3355.6677">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email:</label>
                        <input type="email" name="Email" class="form-control" placeholder="example@domain.com">
                    </div>
                </div>

                @* Cột bên phải *@
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tỉnh/Thành:</label>
                        <select name="Province" class="form-select">
                            <option value="">-- Chọn Tỉnh/Thành --</option>
                            <option value="Hà Nội">Hà Nội</option>
                            <option value="TP. Hồ Chí Minh">TP. Hồ Chí Minh</option>
                            <option value="Bắc Ninh">Bắc Ninh</option>
                            @* Thêm các tỉnh thành khác ở đây *@
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ:</label>
                        <input type="text" name="Address" class="form-control" placeholder="Số nhà, tên đường...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ghi chú:</label>
                        <textarea name="Note" class="form-control" rows="4" placeholder="Thông tin bổ sung (nếu có)"></textarea>
                    </div>
                </div>
            </div>

            <hr />

            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy"></i> Lưu dữ liệu
                </button>
                <a href="/Supplier" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>