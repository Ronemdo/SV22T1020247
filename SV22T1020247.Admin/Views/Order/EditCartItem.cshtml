@model SV22T1020247.Models.Sales.OrderDetailViewInfo
@{
    Layout = null;
}
<form action="~/Order/UpdateCartItem" method="post" onsubmit="updateCartItem(event, this)">

    <div class="modal-header">
        <strong class="modal-title">
            Cập nhật mặt hàng trong giỏ hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="container-fluid">
            <input type="hidden" name="productID" value="@Model.ProductID" />

            <div class="row">
                <div class="col-md-8">
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Mặt hàng
                        </label>
                        <div class="col-sm-8">
                            <span class="form-control-plaintext">@Model.ProductName</span>
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Số lượng
                        </label>
                        <div class="col-sm-8">
                            <input type="number" class="form-control" name="quantity" value="@Model.Quantity" min="1" required />
                        </div>
                    </div>

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">
                            Đơn giá
                        </label>
                        <div class="col-sm-8">
                            <input type="number" class="form-control" name="salePrice" value="@Model.SalePrice" min="0" required />
                        </div>
                    </div>
                </div>

                <div class="col-md-4 text-end">
                    <img src="~/images/products/@(string.IsNullOrWhiteSpace(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         alt="@Model.ProductName"
                         class="img-thumbnail"
                         style="max-height:180px">
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            Cập nhật
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>