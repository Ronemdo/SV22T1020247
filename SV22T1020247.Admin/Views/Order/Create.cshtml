@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>
            <!--Search-->
            <div class="card-body">
                <form id="formSearchProduct"  class="mb-3"
                      action="~/Order/SearchProduct"
                      data-target="productSearchResult"
                      method="get" 
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" name="PageSize" value="@Model.PageSize" />

                    <div class="input-group mb-3">
                        <input type="text" name="SearchValue" class="form-control"
                               placeholder="Nhập tên mặt hàng..." value="@Model.SearchValue" />

                        <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                    </div>
                </form>

                <div id="productSearchResult">
                    <p class="text-center text-muted">Đang tải dữ liệu...</p>
                </div>
            </div>

        </div>
    </div>
    <!--Giỏ hàng và thông ti n của khách hàng-->
    <div class="col-8">
        <div class="row">
            <div class="col-12" id="cart">
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form method="post" onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID">
                                        <option value="0">-- Chọn khách hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province" asp-items="await SelectListHelper.Provinces()">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Khi quay lại trang, tự động kích hoạt tìm kiếm với trang cũ
            paginationSearch(null, document.getElementById("formSearchProduct"), @Model.Page);
            showCart();
        });
                async function showCart() {
            // 1. Lấy thẻ HTML có id là "cart"
            const cartElement = document.getElementById('cart');

            if (!cartElement) {
                console.error('Không tìm thấy phần tử có id="cart"');
                return;
            }

            // Hiển thị trạng thái đang tải cho người dùng biết
            cartElement.innerHTML = '<p>Đang tải giỏ hàng...</p>';

            try {
                // 2. Gọi API bằng phương thức GET
                const response = await fetch('/Order/ShowCart', {
                    method: 'GET'
                    // Nếu API cần gửi kèm token (cookie/session) thì thêm thông số vào đây
                    // credentials: 'omit' | 'same-origin' | 'include'
                });

                // Kiểm tra xem request có thành công không
                if (!response.ok) {
                    throw new Error(`Lỗi HTTP! Trạng thái: ${response.status}`);
                }

                // 3. ĐỌC DỮ LIỆU DƯỚI DẠNG TEXT (chuỗi HTML)
                const htmlContent = await response.text();

                // 4. Gắn trực tiếp đoạn HTML nhận được vào thẻ cart
                cartElement.innerHTML = htmlContent;

            } catch (error) {
                // Xử lý khi có lỗi xảy ra
                console.error('Lỗi khi tải giao diện giỏ hàng:', error);
                cartElement.innerHTML = '<p style="color: red;">Đã xảy ra lỗi khi tải dữ liệu giỏ hàng. Vui lòng thử lại sau.</p>';
            }
        }

        async function addCartItem(event, form) {
    // Ngăn chặn trang bị tải lại khi submit form
    event.preventDefault();

    try {
        // Thu thập toàn bộ dữ liệu từ form
        const formData = new FormData(form);

        // Gửi yêu cầu POST tới API
        const response = await fetch('/Order/AddCartItem', {
            method: 'POST',
            body: formData
        });

        // Chuyển đổi dữ liệu trả về thành JSON
        const data = await response.json();

        // Xử lý logic dựa trên trường 'code'
        if (data.code === 0) {
            // Hiển thị thông báo lỗi (bạn có thể thay alert bằng cách hiển thị lên UI)
            alert(data.message);
        } else {
            // Gọi hàm showCart() nếu thành công
            showCart();
        }
    } catch (error) {
        // Bắt lỗi trong trường hợp mất mạng hoặc server lỗi
        console.error('Lỗi khi thêm vào giỏ hàng:', error);
        alert('Đã xảy ra lỗi hệ thống, vui lòng thử lại sau.');
    }
    }

            async function deleteCartItem(productID) {
            try {
                // Gọi API với phương thức POST
                const response = await fetch(`/Order/DeleteCartItem?productId=${productID}`, {
                    method: 'POST',
                    headers: {
                        // Thêm headers nếu server của bạn yêu cầu (ví dụ: xác thực, CSRF token, v.v.)
                        'Content-Type': 'application/json'
                    }
                });

                // Kiểm tra xem request có thành công không (status code 200-299)
                if (response.ok) {
                    console.log(`Đã xóa sản phẩm ${productID} khỏi giỏ hàng.`);

                    // Gọi hàm showCart() sau khi xóa thành công
                    showCart();
                } else {
                    console.error('Lỗi khi xóa sản phẩm. Mã lỗi:', response.status);
                    alert('Có lỗi xảy ra khi xóa sản phẩm. Vui lòng thử lại!');
                }
            } catch (error) {
                // Bắt các lỗi về mạng hoặc lỗi cú pháp
                console.error('Lỗi kết nối API:', error);
                alert('Không thể kết nối đến máy chủ.');
            }
        }
            async function clearCart() {
                if (confirm("Bạn có chắc chắn muốn xóa toàn bộ mặt hàng trong giỏ?")) {
                    try {
                        // Gọi API với phương thức POST
                        const response = await fetch('/Order/ClearCart', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            }
                        });

                        // Kiểm tra xem request có thành công không
                        if (response.ok) {
                            console.log("Đã xóa toàn bộ giỏ hàng.");
                            // Gọi hàm showCart() để cập nhật lại giao diện ngay lập tức
                            showCart();
                        } else {
                            console.error('Lỗi khi xóa giỏ hàng. Mã lỗi:', response.status);
                            alert('Có lỗi xảy ra khi xóa giỏ hàng. Vui lòng thử lại!');
                        }
                    } catch (error) {
                        console.error('Lỗi kết nối API:', error);
                        alert('Không thể kết nối đến máy chủ.');
                    }
                }
            }
                async function submitClearCart(event, form) {
                // Ngăn form load lại trang
                event.preventDefault();

                try {
                    // Gửi yêu cầu POST để xóa
                    const response = await fetch(form.action, { method: 'POST' });
                    const data = await response.json();

                    if (data.code === 1) {
                        // Đóng modal Bootstrap 5 giống hệt hàm updateCartItem của bạn
                        const modalElement = document.getElementById('dialogModal');
                        if (modalElement) {
                            const modalInstance = bootstrap.Modal.getInstance(modalElement);
                            if (modalInstance) {
                                modalInstance.hide();
                            }
                        }
                        // Load lại bảng giỏ hàng
                        showCart();
                    } else {
                        alert("Lỗi: " + data.message);
                    }
                } catch (error) {
                    console.error("Lỗi xóa giỏ hàng:", error);
                }
            }
                async function updateCartItem(event, form) {
    event.preventDefault(); // Ngăn trình duyệt load lại trang
    
    try {
        const formData = new FormData(form);
        const response = await fetch(form.action, {
            method: 'POST',
            body: formData
        });
        
        const data = await response.json();

        if (data.code === 1) {
            // Tắt Modal
            const modalElement = document.getElementById('dialogModal'); 
            if (modalElement) {
                const modalInstance = bootstrap.Modal.getInstance(modalElement);
                if (modalInstance) {
                    modalInstance.hide();
                }
            }
            // Gọi hàm load lại bảng giỏ hàng
            showCart();
        } else {
            alert(data.message); 
        }
    } catch (error) {
        console.error("Lỗi:", error);
    }
}
            async function submitCreateOrder(event, form) {
            event.preventDefault(); // Ngăn load lại trang

            try {
                const formData = new FormData(form);
                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                // Trong C# của bạn: return Json(new ApiResult(orderID));
                // Nếu tạo thành công, C# sẽ trả về code chính là mã đơn hàng (lớn hơn 0)
                // Nếu thất bại (giỏ rỗng), trả về code = 0 kèm message

                if (data.code > 0) {
                    alert("Tạo đơn hàng thành công!");
                    // Chuyển hướng sang trang chi tiết đơn hàng
                    window.location.href = "/Order/Detail/" + data.code;
                } else {
                    // Báo lỗi (ví dụ: "Giỏ hàng trống, không lập được đơn hàng")
                    alert("Lỗi: " + data.message);
                }
            } catch (error) {
                console.error("Lỗi khi lập đơn:", error);
                alert("Có lỗi kết nối xảy ra!");
            }
        }
                async function createOrder(event, form) {
            // 1. Ngăn chặn hành vi submit mặc định của form (tránh reload lại trang)
            event.preventDefault();

            try {
                // 2. Thu thập dữ liệu từ form
                const formData = new FormData(form);

                // 3. Gửi request POST lên API
                const response = await fetch('/Order/CreateOrder', {
                    method: 'POST',
                    body: formData
                });

                // Kiểm tra xem HTTP request có thành công không (status 200-299)
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                // 4. Parse kết quả trả về dưới dạng JSON
                const result = await response.json();

                // 5. Xử lý logic điều hướng hoặc báo lỗi dựa theo "code"
                if (result.code === 0) {
                    // Thông báo lỗi (bạn có thể thay alert bằng thư viện toast/modal của bạn)
                    alert(result.message || 'Đã có lỗi xảy ra trong quá trình tạo đơn hàng!');
                } else {
                    // Chuyển hướng về trang chi tiết đơn hàng
                    window.location.href = `/Order/Detail/${result.code}`;
                }

            } catch (error) {
                console.error('Lỗi khi gọi API CreateOrder:', error);
                alert('Lỗi kết nối đến máy chủ. Vui lòng thử lại sau!');
            }
        }
    </script>
}