@{
    ViewBag.Title = "Xác nhận xóa ảnh";

    // 1. Lấy ID thật từ Controller gửi sang (QUAN TRỌNG)
    var realProductID = ViewBag.ProductID;

    // --- MOCK DATA ---
    var p = new
    {
        PhotoID = 101,             // ID Con (Ảnh)
        ProductID = realProductID, // <--- SỬA Ở ĐÂY: Dùng ID thật thay vì số 1
        Photo = "https://via.placeholder.com/300x300",
        Description = "Ảnh mặt trước"
    };
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            <div class="card shadow border-danger border-2">
                <div class="card-body text-center p-4">

                    <div class="text-danger mb-3">
                        <i class="fas fa-exclamation-triangle fa-3x"></i>
                    </div>

                    <h4 class="fw-bold text-danger mb-2">Xác nhận xóa ảnh?</h4>
                    <p class="text-muted mb-4">
                        Hành động này không thể hoàn tác.<br>
                        Bạn có chắc chắn muốn xóa ảnh này không?
                    </p>

                    <div class="p-2 border rounded bg-light d-inline-block mb-4 position-relative">
                        <img src="@p.Photo" class="img-fluid rounded" style="max-height: 200px;">
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            <i class="fas fa-times"></i>
                        </span>
                    </div>

                    <form action="/Product/DeletePhoto/@p.ProductID?photoId=@p.PhotoID" method="post">

                        <input type="hidden" name="ProductID" value="@p.ProductID" />
                        <input type="hidden" name="PhotoID" value="@p.PhotoID" />

                        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                            <a href="/Product/ListPhotos/@p.ProductID" class="btn btn-light border px-4">
                                Không, quay lại
                            </a>

                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                <i class="fas fa-trash-alt me-1"></i> Có, xóa ngay
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>