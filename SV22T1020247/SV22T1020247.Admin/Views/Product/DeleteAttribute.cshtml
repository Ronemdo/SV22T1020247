@{
    ViewBag.Title = "Xác nhận xóa";

    // 1. Lấy ID thật từ Controller gửi sang
    var realProductID = ViewBag.ProductID;

    // --- MOCK DATA ---
    var attr = new
    {
        AttributeID = 123,       // ID Con
        ProductID = realProductID, // <--- SỬA Ở ĐÂY: Dùng ID thật
        Name = "Màu sắc",
        Value = "Titan Xanh"
    };
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow border-danger border-2">
                <div class="card-body text-center p-4">

                    <div class="text-danger mb-3">
                        <i class="fas fa-trash-alt fa-3x"></i>
                    </div>

                    <h4 class="fw-bold text-danger mb-2">Xác nhận xóa?</h4>
                    <p class="text-muted mb-4 small">
                        Bạn có chắc chắn muốn xóa thuộc tính này không?<br>
                        Hành động này <strong>không thể hoàn tác</strong>.
                    </p>

                    <div class="alert alert-light border border-secondary border-opacity-25 d-inline-block text-start px-4 py-2 mb-4 shadow-sm" style="min-width: 200px;">
                        <div class="mb-1">
                            <span class="text-muted small">Tên:</span>
                            <span class="fw-bold text-dark">@attr.Name</span>
                        </div>
                        <div>
                            <span class="text-muted small">Giá trị:</span>
                            <span class="fw-bold text-dark">@attr.Value</span>
                        </div>
                    </div>

                    <form action="/Product/DeleteAttribute/@attr.ProductID?attributeId=@attr.AttributeID" method="post">

                        <input type="hidden" name="ProductID" value="@attr.ProductID">
                        <input type="hidden" name="AttributeID" value="@attr.AttributeID">

                        <div class="d-flex justify-content-center gap-2">
                            <a href="/Product/ListAttributes/@attr.ProductID" class="btn btn-light border px-3">
                                Không, quay lại
                            </a>
                            <button type="submit" class="btn btn-danger px-4 fw-bold">
                                <i class="fas fa-check me-1"></i> Có, xóa ngay
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>