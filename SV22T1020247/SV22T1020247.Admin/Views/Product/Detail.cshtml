@{
    ViewBag.Title = "Chi tiết mặt hàng";
    var productId = ViewBag.ProductID;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Product" class="text-decoration-none text-muted">Danh sách</a></li>
                <li class="breadcrumb-item active fw-bold text-dark" aria-current="page">Chi tiết sản phẩm</li>
            </ol>
        </nav>
        <div>
            <a href="/Product" class="btn btn-sm btn-outline-secondary me-2">
                <i class="fas fa-arrow-left me-1"></i> Quay lại
            </a>
            <a href="/Product/Edit/@productId" class="btn btn-sm btn-primary">
                <i class="fas fa-edit me-1"></i> Sửa thông tin
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card border-0 shadow-sm">
                <div class="p-3 text-center bg-light rounded-top">
                    <img src="https://via.placeholder.com/400x400" class="img-fluid rounded" style="max-height: 350px; object-fit: contain;">
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2 overflow-auto pb-2 justify-content-center">
                        <img src="https://via.placeholder.com/80" class="rounded border p-1 border-primary" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;">
                        <img src="https://via.placeholder.com/80" class="rounded border p-1" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;">
                        <img src="https://via.placeholder.com/80" class="rounded border p-1" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;">
                        <div class="rounded border bg-light d-flex align-items-center justify-content-center text-muted small" style="width: 70px; height: 70px; cursor: pointer;">
                            +3
                        </div>
                    </div>
                    <div class="text-center mt-2">
                        <a href="/Product/ListPhotos/@productId" class="small text-decoration-none fw-bold">
                            <i class="fas fa-images"></i> Quản lý thư viện ảnh
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <h3 class="fw-bold text-dark mb-1">Điện thoại iPhone 15 Pro Max</h3>
            <div class="mb-3 d-flex align-items-center">
                <span class="fs-4 fw-bold text-danger me-3">30.000.000 ₫</span>
                <span class="badge bg-success bg-opacity-10 text-success border border-success px-3">Đang kinh doanh</span>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom fw-bold text-secondary">
                    <i class="fas fa-info-circle me-1"></i> Thông tin chi tiết
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted ps-4 py-2" style="width: 35%;">Loại hàng:</td>
                                <td class="fw-bold py-2">Điện tử</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-4 py-2">Đơn vị tính:</td>
                                <td class="fw-bold py-2">Cái</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-4 py-2">Nhà cung cấp:</td>
                                <td class="py-2"><a href="#" class="text-decoration-none fw-bold">Công ty Apple</a></td>
                            </tr>

                            <tr><td colspan="2"><hr class="my-1 text-muted opacity-25"></td></tr>

                            <tr>
                                <td class="text-muted ps-4 py-2">Màu sắc:</td>
                                <td class="py-2">Titan Xanh, Titan Tự nhiên</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-4 py-2">Dung lượng:</td>
                                <td class="py-2">256GB, 512GB</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-4 py-2">RAM:</td>
                                <td class="py-2">8GB</td>
                            </tr>
                            <tr>
                                <td class="text-muted ps-4 py-2">Chip xử lý:</td>
                                <td class="py-2">Apple A17 Pro</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white border-top-0 text-end">
                    <a href="/Product/ListAttributes/@productId" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-cog me-1"></i> Cập nhật thuộc tính
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* CSS bổ sung để làm đẹp */
    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0,0.015);
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }
</style>